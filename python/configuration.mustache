from dataclasses import dataclass, field


@dataclass
class Configuration:
    base_url: str = "{{#basePath}}{{{basePath}}}{{/basePath}}{{^basePath}}http://localhost{{/basePath}}"
    timeout: float = 30.0
    api_key: str | None = None
    access_token: str | None = None
    default_headers: dict[str, str] = field(default_factory=dict)

    def __post_init__(self) -> None:
        if self.api_key and "X-API-Key" not in self.default_headers:
            self.default_headers["X-API-Key"] = self.api_key
        if self.access_token and "Authorization" not in self.default_headers:
            self.default_headers["Authorization"] = f"Bearer {self.access_token}"
