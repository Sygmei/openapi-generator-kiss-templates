[build-system]
requires = ["hatchling>=1.24.0"]
build-backend = "hatchling.build"

[project]
name = "{{{projectName}}}"
version = "{{{packageVersion}}}"
description = "{{{projectDescription}}}"
readme = "README.md"
requires-python = ">=3.9"
dependencies = [
  "httpx>=0.27.0,<1.0.0",
  "pydantic>=2.0.0,<3.0.0",
]

[tool.hatch.build.targets.wheel]
packages = ["{{{packageName}}}"]
